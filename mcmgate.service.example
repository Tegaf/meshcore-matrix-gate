[Unit]
Description=MCMGate - MeshCore LoRa <-> Matrix bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/path/to/meshcore-matrix-gate/.venv/bin/mcmgate
WorkingDirectory=/path/to/meshcore-matrix-gate
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
